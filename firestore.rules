rules_version = '2';

// Hethvik Interiors — admin-only access.
// All quotes/bills/projects are readable/writable ONLY by the single
// admin account. Everyone else (including unauthenticated requests) is
// denied. Update the UID below if the admin user ever changes.
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.uid == 'gyeOa3JKe1cyFosW5zGEIx6IqKl2';
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
